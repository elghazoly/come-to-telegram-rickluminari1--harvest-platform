{
  "name": "harvest-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:admin":   "pnpm --filter admin dev",
    "dev:teacher": "pnpm --filter teacher dev",
    "dev:student": "pnpm --filter student dev",
